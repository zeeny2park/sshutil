{
  "name": "sshutil",
  "version": "1.0.0",
  "description": "Multi-Hop SSH utility with TUI file explorer, interactive terminal, and streaming file transfer",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "sshutil": "./bin/sshutil.js"
  },
  "scripts": {
    "start": "node bin/sshutil.js",
    "build": "node scripts/build-tui.js",
    "postinstall": "node scripts/build-tui.js",
    "tui": "node bin/sshutil.js tui",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "ssh",
    "tui",
    "multi-hop",
    "file-transfer",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.0",
    "meow": "^13.0.0",
    "react": "^18.3.1",
    "ssh2": "^1.16.0",
    "winston": "^3.17.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@babel/register": "^7.25.9",
    "esbuild": "^0.28.0",
    "esbuild-register": "^3.6.0"
  }
}
